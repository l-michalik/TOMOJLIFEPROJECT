{
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "taskDescription": {
      "type": "string",
      "description": "Natural-language task description passed to the supervisor.",
      "minLength": 10,
      "maxLength": 4000
    },
    "source": {
      "type": "string",
      "description": "Channel from which the request originated.",
      "enum": [
        "jira",
        "chat",
        "api"
      ]
    },
    "requester": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "description": "Identifier of the requesting user for audit purposes.",
          "minLength": 3,
          "maxLength": 128
        },
        "role": {
          "type": "string",
          "description": "Business or technical role of the user.",
          "enum": [
            "admin",
            "devops",
            "platform-engineer",
            "viewer"
          ]
        },
        "displayName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        }
      },
      "minProperties": 1,
      "required": [
        "id"
      ]
    },
    "parameters": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "environment": {
          "type": "string",
          "description": "Target execution environment.",
          "enum": [
            "dev",
            "stage",
            "prod"
          ]
        },
        "serviceName": {
          "type": "string",
          "minLength": 2,
          "maxLength": 128,
          "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._-]*$"
        },
        "operation": {
          "type": "string",
          "description": "Operation type handled by the system.",
          "enum": [
            "deploy",
            "configure",
            "diagnose",
            "restart",
            "rollback",
            "provision"
          ]
        },
        "targetVersion": {
          "type": "string",
          "description": "Artifact or release version to deploy.",
          "minLength": 1,
          "maxLength": 64
        },
        "dryRun": {
          "type": "boolean",
          "description": "Forces read-only or plan-only execution mode."
        },
        "approvalRequired": {
          "type": "boolean",
          "description": "Explicit flag indicating that human approval is required."
        },
        "timeoutSeconds": {
          "type": "integer",
          "minimum": 30,
          "maximum": 86400
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 32
          },
          "minItems": 1,
          "maxItems": 20,
          "uniqueItems": true
        }
      },
      "minProperties": 1
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "ticketId": {
          "type": "string",
          "description": "Jira ticket key when the request originates from Jira.",
          "pattern": "^[A-Z][A-Z0-9]+-\\d+$"
        },
        "threadId": {
          "type": "string",
          "description": "Chat thread identifier when the request originates from chat.",
          "minLength": 1,
          "maxLength": 128
        },
        "correlationId": {
          "type": "string",
          "description": "Identifier used to trace the request across components.",
          "minLength": 8,
          "maxLength": 128
        }
      },
      "minProperties": 1
    }
  },
  "required": [
    "requester",
    "source",
    "taskDescription"
  ],
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AgenticPlatformTaskSubmission",
  "description": "Formal input schema for the Agentic Platform Engineer system for requests coming from Jira, chat, or API.",
  "allOf": [
    {
      "if": {
        "properties": {
          "source": {
            "const": "jira"
          }
        }
      },
      "then": {
        "required": [
          "metadata"
        ],
        "properties": {
          "metadata": {
            "required": [
              "ticketId"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "source": {
            "const": "chat"
          }
        }
      },
      "then": {
        "required": [
          "metadata"
        ],
        "properties": {
          "metadata": {
            "required": [
              "threadId"
            ]
          }
        }
      }
    },
    {
      "if": {
        "required": [
          "parameters"
        ],
        "properties": {
          "parameters": {
            "properties": {
              "environment": {
                "const": "prod"
              }
            }
          }
        }
      },
      "then": {
        "required": [
          "parameters"
        ],
        "properties": {
          "parameters": {
            "properties": {
              "approvalRequired": {
                "const": true
              }
            },
            "required": [
              "approvalRequired"
            ]
          }
        }
      }
    },
    {
      "if": {
        "required": [
          "parameters"
        ],
        "properties": {
          "parameters": {
            "properties": {
              "operation": {
                "enum": [
                  "rollback",
                  "deploy",
                  "restart"
                ]
              }
            }
          }
        }
      },
      "then": {
        "required": [
          "parameters"
        ],
        "properties": {
          "parameters": {
            "required": [
              "serviceName"
            ]
          }
        }
      }
    },
    {
      "if": {
        "required": [
          "parameters"
        ],
        "properties": {
          "parameters": {
            "properties": {
              "operation": {
                "const": "deploy"
              }
            }
          }
        }
      },
      "then": {
        "required": [
          "parameters"
        ],
        "properties": {
          "parameters": {
            "required": [
              "targetVersion"
            ]
          }
        }
      }
    }
  ]
}
